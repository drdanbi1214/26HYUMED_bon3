{
  "buildCommand": "",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "crons": [
    { "path": "/api/send-push", "schedule": "0 14 * * *" },
    { "path": "/api/send-push", "schedule": "* 4 * * *" }
  ]
}
